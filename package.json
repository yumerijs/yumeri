{
  "name": "yumeri-dev",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "package/*",
    "plugins/*",
    "renderer/*",
    "common/*"
  ],
  "scripts": {
    "start": "yumeri start",
    "dev": "cross-env NODE_ENV=development yumeri start --import @hirarijs/loader/import",
    "setup": "yumeri-scripts setup",
    "build": "yumeri-scripts build"
  },
  "dependencies": {
    "@hirarijs/loader": "^1.0.19",
    "@hirarijs/loader-ts": "^1.0.20",
    "@hirarijs/loader-tsx": "^1.0.0",
    "@hirarijs/loader-vue": "^1.0.0",
    "@yumerijs/scripts": "workspace:^",
    "yumeri": "workspace:^",
    "yumeri-plugin-console": "workspace:^"
  },
  "devDependencies": {
    "@types/fs-extra": "^11",
    "@types/node": "^22.15.19",
    "cross-env": "^10.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@4.9.2"
}
